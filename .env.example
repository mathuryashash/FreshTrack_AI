# FreshTrack AI — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# ── API Security ──────────────────────────────────────────────────────
# Set a strong random string to enable API key authentication on /predict and /feedback.
# Leave blank to disable auth (development only).
API_KEY=

# Comma-separated list of allowed Host headers (e.g. yourdomain.com,localhost).
# Leave blank to disable TrustedHostMiddleware (development only).
TRUSTED_HOSTS=

# Comma-separated allowed CORS origins.
# Leave blank to allow all origins "*" (development only, not recommended for production).
# Example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=

# Set to 1, true, or yes to enable /docs and /redoc endpoints (development only).
DEBUG=

# ── Model ─────────────────────────────────────────────────────────────
MODEL_CHECKPOINT=models/checkpoints/freshtrack_epoch=04_val_loss=0.01-v1.ckpt

# SHA-256 checksum of the model checkpoint for integrity verification.
# Leave empty to skip verification (not recommended for production).
MODEL_SHA256=

# ── Database ───────────────────────────────────────────────────────
# SQLite database path (use .db extension)
DATABASE_URL=data/freshtrack.db

# ── API Server ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ── Logging ──────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── External Services ────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=
KAGGLE_API_KEY=
KAGGLE_USERNAME=
