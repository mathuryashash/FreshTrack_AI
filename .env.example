# FreshTrack AI Environment Variables
# Copy this file to .env and fill in your values

# OpenWeatherMap API Key (for Streamlit weather integration)
OPENWEATHERMAP_API_KEY=

# Kaggle API credentials (for auto_train.py dataset downloads)
KAGGLE_API_KEY=
KAGGLE_USERNAME=

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
